# Client environment

# App mode
VITE_DATA_SOURCE=kingston

# Socket.IO server URL for Kingston simulator mode
VITE_SOCKET_URL=http://localhost:3001

# Optional API base URL. Leave blank to use the same origin / Vite proxy.
VITE_API_BASE_URL=

# NYC mode
VITE_MAPBOX_ACCESS_TOKEN=
VITE_GOOGLE_MAPS_BROWSER_KEY=
