# Backend environment

# Spring Boot HTTP port
SERVER_PORT=8080

# Socket.IO port for Kingston simulator mode
SOCKETIO_PORT=3001

# Data source: simulator or mta
TRANSIT_DATA_SOURCE=simulator

# Kingston simulator update interval (ms)
SIMULATOR_UPDATE_INTERVAL=2000

# NYC MTA integration
TRANSIT_MTA_API_KEY=
MTA_BUSTIME_API_KEY=
